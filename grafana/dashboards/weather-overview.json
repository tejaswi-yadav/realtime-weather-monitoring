{
  "title": "Weather Overview Dashboard",
  "description": "Complete weather monitoring overview with temperature, humidity, and conditions",
  "tags": ["weather", "overview"],
  "timezone": "browser",
  "schemaVersion": 16,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "title": "Temperature Over Time",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "weather_temperature_celsius",
          "legendFormat": "{{city}} ({{zip_code}})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "color": {"mode": "palette-classic"},
          "custom": {
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 20
          }
        }
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom"}
      }
    },
    {
      "id": 2,
      "title": "Humidity Over Time",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "weather_humidity_percent",
          "legendFormat": "{{city}} ({{zip_code}})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": {"mode": "palette-classic"},
          "custom": {
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 20
          }
        }
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom"}
      }
    },
    {
      "id": 6,
      "title": "Wind Speed Over Time",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [
        {
          "expr": "weather_wind_speed_ms",
          "legendFormat": "{{city}} ({{zip_code}})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "velocityms",
          "color": {"mode": "palette-classic"},
          "custom": {
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 20
          }
        }
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom"}
      }
    },
    {
      "id": 7,
      "title": "Pressure Over Time",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "targets": [
        {
          "expr": "weather_pressure_hpa",
          "legendFormat": "{{city}} ({{zip_code}})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "pressurehpa",
          "color": {"mode": "palette-classic"},
          "custom": {
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 20
          }
        }
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom"}
      }
    },
    {
      "id": 3,
      "title": "Temperature by ZIP Code",
      "type": "table",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "targets": [
        {
          "expr": "weather_temperature_celsius",
          "format": "table",
          "refId": "A",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {},
            "indexByName": {
              "zip_code": 0,
              "city": 1,
              "datetime": 2,
              "Value": 3
            },
            "renameByName": {
              "Value": "Temperature (°C)"
            }
          }
        }
      ]
    },
    {
      "id": 4,
      "title": "Messages Processed",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 16},
      "targets": [
        {
          "expr": "sum(weather_messages_processed_total)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    },
    {
      "id": 5,
      "title": "Processing Errors",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 16},
      "targets": [
        {
          "expr": "sum(weather_message_errors_total)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "steps": [
              {"value": null, "color": "green"},
              {"value": 1, "color": "yellow"},
              {"value": 10, "color": "red"}
            ]
          }
        }
      }
    },
    {
      "id": 8,
      "title": "Active Weather Alerts",
      "type": "table",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 20},
      "targets": [
        {
          "expr": "ALERTS{alertname=~\"HighWindSpeed|HighPressure|LowPressure|HighTemperature|LowTemperature|HighHumidity|LowHumidity\",alertstate=\"firing\"}",
          "format": "table",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "displayMode": "list"
          }
        }
      }
    }
  ]
}
