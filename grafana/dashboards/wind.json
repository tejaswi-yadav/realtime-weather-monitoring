{
  "title": "Weather Wind Speed Monitoring",
  "description": "Real-time wind speed monitoring across different cities",
  "tags": ["weather", "wind"],
  "timezone": "browser",
  "schemaVersion": 16,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "title": "Wind Speed by City",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "weather_wind_speed_ms",
          "legendFormat": "{{city}} ({{zip_code}}) - {{datetime}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "velocityms",
          "color": {"mode": "palette-classic"},
          "custom": {
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 20,
            "drawStyle": "line"
          }
        }
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom"}
      }
    },
    {
      "id": 2,
      "title": "Current Wind Speed",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "weather_wind_speed_ms",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "velocityms",
          "thresholds": {
            "steps": [
              {"value": null, "color": "green"},
              {"value": 10, "color": "yellow"},
              {"value": 15, "color": "red"}
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Active Wind Alerts",
      "type": "table",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "targets": [
        {
          "expr": "ALERTS{alertname=\"HighWindSpeed\",alertstate=\"firing\"}",
          "format": "table",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "displayMode": "list"
          }
        }
      }
    }
  ]
}

