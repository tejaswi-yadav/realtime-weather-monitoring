{
  "title": "Weather Temperature Monitoring",
  "description": "Real-time temperature monitoring across different cities",
  "tags": ["weather", "temperature"],
  "timezone": "browser",
  "schemaVersion": 16,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "title": "Temperature by City",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "weather_temperature_celsius",
          "legendFormat": "{{city}} ({{zip_code}}) - {{datetime}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "color": {"mode": "palette-classic"},
          "custom": {
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 20,
            "drawStyle": "line"
          }
        }
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom"}
      }
    },
    {
      "id": 2,
      "title": "Current Temperature",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "weather_temperature_celsius",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "thresholds": {
            "steps": [
              {"value": null, "color": "blue"},
              {"value": 0, "color": "yellow"},
              {"value": 25, "color": "red"}
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Temperature by Date",
      "type": "bargauge",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "targets": [
        {
          "expr": "weather_temperature_celsius",
          "legendFormat": "{{date}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "celsius"
        }
      }
    }
  ]
}

